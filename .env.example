# AquaOS Local Environment Configuration
# Copy this file to a new file named '.env' in the same directory and add your keys.
# Do NOT commit '.env' to version control.

# ── LLM Provider (choose one) ──────────────────────────────────────────
#
# Option A: OpenRouter (recommended — all providers via one key)
#   Get your key at https://openrouter.ai/keys
#   Per-agent optimal models: DeepSeek V3, Claude 3.5 Haiku, Gemini 2.0 Flash
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Option B: Google Gemini direct (single model, simpler)
#   Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# ── React Frontend ─────────────────────────────────────────────────────
# Only needed for local frontend dev (AgentHub.jsx direct Gemini calls)
VITE_GEMINI_API_KEY=your_actual_gemini_api_key_here
