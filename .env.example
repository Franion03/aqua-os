# AquaOS Local Environment Configuration
# Copy this file to a new file named '.env' in the same directory and add your key.
# Do NOT commit '.env' to version control (it is added to .gitignore automatically).

# Google Gemini API Key
# Get your API key from Google AI Studio (https://aistudio.google.com/)
VITE_GEMINI_API_KEY=your_actual_gemini_api_key_here
