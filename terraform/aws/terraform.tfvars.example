# ── AquaOS PoC — Example Variables ───────────────────────────────────────
# Copy to terraform.tfvars and fill in your values.

# Your local SSH public key (~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI..."

# Your home/office IP for SSH access (find via: curl ifconfig.me)
# Use /32 for a single IP (e.g., "83.45.123.67/32")
allowed_ssh_cidr = "0.0.0.0/0" # ⚠️ RESTRICT THIS TO YOUR IP

# Google Gemini API key (https://aistudio.google.com/)
gemini_api_key = "AIza..."

# OpenRouter API key (https://openrouter.ai/keys) — multi-model LLM routing
openrouter_api_key = "sk-or-v1-..."

# Optional overrides
# aws_region       = "eu-west-1"
# instance_type    = "t3.micro"
# root_volume_size = 20
