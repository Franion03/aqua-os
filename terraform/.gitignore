# ── Terraform ────────────────────────────────────────────────────────────
# Local .terraform directories
**/.terraform/*

# Terraform state files (NEVER commit these)
*.tfstate
*.tfstate.*
*.tfvars
!terraform.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc
